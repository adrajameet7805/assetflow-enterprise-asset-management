generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── Enums as String (SQLite has no native enum) ─────────────────────────────
// UserRole:  ADMIN | ASSET_MANAGER | DEPARTMENT_HEAD | EMPLOYEE
// AssetStatus: AVAILABLE | ALLOCATED | RESERVED | UNDER_MAINTENANCE | LOST | RETIRED | DISPOSED
// AllocationTransferStatus: REQUESTED | APPROVED | REALLOCATED
// BookingStatus: UPCOMING | ONGOING | COMPLETED | CANCELLED
// MaintenanceStatus: PENDING | APPROVED | REJECTED | TECHNICIAN_ASSIGNED | IN_PROGRESS | RESOLVED
// AuditItemStatus: VERIFIED | MISSING | DAMAGED

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("EMPLOYEE") // ADMIN | ASSET_MANAGER | DEPARTMENT_HEAD | EMPLOYEE
  departmentId String?
  status       String   @default("ACTIVE")   // ACTIVE | INACTIVE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Feature relations
  allocations         Allocation[]         @relation("EmployeeAllocations")
  requestedTransfers  Allocation[]         @relation("RequestedTransfers")
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[] @relation("RaisedMaintenance")
  assignedMaintenance MaintenanceRequest[] @relation("TechnicianMaintenance")
  auditedItems        AuditItem[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
}

model Department {
  id       String       @id @default(cuid())
  name     String
  headId   String?
  parentId String?
  status   String       @default("ACTIVE")
  parent   Department?  @relation("DeptHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Department[] @relation("DeptHierarchy")
  users    User[]

  assets                 Asset[]
  allocations            Allocation[]
  requestedTransfersDept Allocation[] @relation("RequestedTransfersDept")
}

model AssetCategory {
  id           String  @id @default(cuid())
  name         String
  customFields String? // JSON stored as text for SQLite
  assets       Asset[]
}

model Asset {
  id              String   @id @default(cuid())
  tag             String   @unique
  name            String
  categoryId      String
  serialNumber    String?
  acquisitionDate DateTime?
  acquisitionCost Decimal?
  condition       String
  location        String
  status          String   @default("AVAILABLE") // AssetStatus
  isBookable      Boolean  @default(false)
  photoUrls       String   @default("[]") // JSON array stored as text for SQLite
  documentUrls    String   @default("[]") // JSON array stored as text for SQLite
  departmentId    String?

  category   AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  department Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  allocations         Allocation[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]

  @@index([tag, status, departmentId])
}

model Allocation {
  id                 String    @id @default(cuid())
  assetId            String
  employeeId         String?
  departmentId       String?
  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?
  returnedAt                 DateTime?
  conditionOnReturn          String?
  transferStatus             String?   // AllocationTransferStatus
  transferRequestedById      String?
  transferRequestedDeptId    String?
  transferExpectedReturnDate DateTime?

  asset                  Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee               User?       @relation("EmployeeAllocations", fields: [employeeId], references: [id], onDelete: SetNull)
  department             Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  transferRequestedBy    User?       @relation("RequestedTransfers", fields: [transferRequestedById], references: [id], onDelete: SetNull)
  transferRequestedDept  Department? @relation("RequestedTransfersDept", fields: [transferRequestedDeptId], references: [id], onDelete: SetNull)

  @@index([assetId, employeeId, departmentId])
}

model Booking {
  id         String   @id @default(cuid())
  assetId    String
  bookedById String
  startTime  DateTime
  endTime    DateTime
  status     String   @default("UPCOMING") // BookingStatus

  asset    Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bookedBy User  @relation(fields: [bookedById], references: [id], onDelete: Cascade)

  @@index([assetId, startTime, endTime])
}

model MaintenanceRequest {
  id             String   @id @default(cuid())
  assetId        String
  raisedById     String
  issue          String
  priority       String
  photoUrl       String?
  status         String   @default("PENDING") // MaintenanceStatus
  technicianId   String?
  resolutionNote String?

  asset      Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  raisedBy   User  @relation("RaisedMaintenance", fields: [raisedById], references: [id], onDelete: Cascade)
  technician User? @relation("TechnicianMaintenance", fields: [technicianId], references: [id], onDelete: SetNull)

  @@index([assetId, status])
}

model AuditCycle {
  id          String   @id @default(cuid())
  scopeDeptId String?
  location    String?
  startDate   DateTime
  endDate     DateTime
  closed      Boolean  @default(false)

  auditItems AuditItem[]

  @@index([startDate, endDate, closed])
}

model AuditItem {
  id           String    @id @default(cuid())
  auditCycleId String
  assetId      String
  auditorId    String
  status       String?   // AuditItemStatus
  note         String?

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  auditor    User       @relation(fields: [auditorId], references: [id], onDelete: Cascade)

  @@index([auditCycleId, assetId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  entity    String
  entityId  String
  metadata  String?  // JSON stored as text for SQLite
  createdAt DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([entity, entityId])
}

model TagSequence {
  id    String @id @default("ASSET")
  value Int    @default(0)
}
